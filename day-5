class Solution {
    public int xorAfterQueries(int[] nums, int[][] queries) {
        final int MOD = 1000000007;

        for (int[] q : queries) {
            int li = q[0], ri = q[1], ki = q[2], vi = q[3];

            for (int idx = li; idx <= ri; idx += ki) {
                nums[idx] = (int)(((long)nums[idx] * vi) % MOD);
            }
        }

        int result = 0;
        for (int num : nums) {
            result ^= num;
        }
        return result;
        
    }
}
